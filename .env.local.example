# Copy this to .env.local and fill in your values

# Supabase — get from https://supabase.com/dashboard/project/<your-project>/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Node.js backend URL (never put AI provider keys in this file — Anthropic/OpenAI/ElevenLabs go in the backend)
EXPO_PUBLIC_API_URL=http://localhost:3001

# PostHog analytics — https://app.posthog.com
EXPO_PUBLIC_POSTHOG_KEY=your_key_here
